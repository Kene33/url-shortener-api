# Published application URL used when generating short links.
ENVIRONMENT=development
PUBLIC_BASE_URL=http://localhost:3000

# Keep this path inside the sqlite_data volume mounted by Compose.
DATABASE_PATH=/app/data/links.db
# Production: Supabase PostgreSQL connection string (use the Session Pooler URL).
# When set, this takes precedence over DATABASE_PATH.
DATABASE_URL=

# The hostname is the Compose service name and is only resolvable in its network.
REDIS_URL=redis://redis:6379/0

# Replace with a long random value before any public deployment.
AUTH_SECRET_KEY=development-only-change-me
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_COOKIE_NAME=linkcutter_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/api/v1
EMAIL_VERIFICATION_HOURS=24
PASSWORD_RESET_MINUTES=30
EMAIL_2FA_CODE_MINUTES=10
EMAIL_PROVIDER_CONFIGURED=false

# Local avatar storage and account-deletion link retention.
AVATAR_DIR=/app/data/avatars
USER_LINK_RETENTION_DAYS_DEFAULT=365

# Users registering with these normalized emails receive the admin role.
ADMIN_EMAILS=["admin@example.com", "admin1@example.com"]

# Keep false while email delivery is not configured. Set true after adding a mail provider.
EMAIL_VERIFICATION_REQUIRED=false

# pydantic-settings expects a JSON array for list-valued environment variables.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Host port mapped to container port 8000.
APP_PORT=8000
FRONTEND_PORT=3000
